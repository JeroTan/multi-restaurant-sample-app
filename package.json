{
  "name": "multi-restaurant-qr-ordering",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check": "next check",
    "build:worker": "npx @opennextjs/cloudflare",
    "dev:worker": "wrangler dev",
    "deploy": "npm run build:worker && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply multi-restaurant-db --local"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "drizzle-orm": "^0.30.10",
    "next-intl": "^3.12.0",
    "qrcode": "^1.5.3",
    "lucide-react": "^0.378.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0",
    "jose": "^5.2.4"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "drizzle-kit": "^0.21.1",
    "wrangler": "^3.57.1",
    "@opennextjs/cloudflare": "^0.2.0"
  }
}
