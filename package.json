{
  "name": "multi-restaurant-qr-ordering",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npm run preview",
    "lint": "next lint",
    "check": "next check",
    "typecheck": "tsc --noEmit",
    "build:worker": "npx opennextjs-cloudflare build",
    "dev:worker": "wrangler dev",
    "preview": "npm run build:worker && wrangler dev",
    "deploy": "npm run build:worker && npx opennextjs-cloudflare deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply multi-restaurant-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply multi-restaurant-db --remote"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.30.10",
    "jose": "^5.10.0",
    "lucide-react": "^0.378.0",
    "next": "^15.0.0",
    "next-intl": "^3.12.0",
    "qrcode": "^1.5.3",
    "react": "^19.0.0-rc.1",
    "react-dom": "^19.0.0-rc.1",
    "react-qr-code": "^2.0.18",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260422.1",
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "drizzle-kit": "^0.21.1",
    "eslint": "^8",
    "eslint-config-next": "15.0.0",
    "postcss": "^8",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "wrangler": "^4.85.0"
  }
}
